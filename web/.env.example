# TrustPay Escrow web — environment template
# Copy to .env.local and fill in.

# Public RPC + chain id. Default = local anvil (31337).
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Deployed contract addresses (output of `forge script Deploy`).
NEXT_PUBLIC_MOCK_USDC=0x5FbDB2315678afecb367f032d93F642f64180aa3
NEXT_PUBLIC_ESCROW_FACTORY=0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512

# Required by RainbowKit. Get one at https://cloud.walletconnect.com (free).
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID
