{
  "name": "trustpay-escrow",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "contracts:build": "cd contracts && forge build",
    "contracts:test": "cd contracts && forge test -vv",
    "contracts:deploy:local": "cd contracts && PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80 forge script script/Deploy.s.sol --rpc-url http://127.0.0.1:8545 --broadcast",
    "contracts:sync-web": "node scripts/sync-web.mjs",
    "demo:up": "bash scripts/demo-up.sh",
    "demo:smoke": "pnpm --filter web exec tsx scripts/demo-smoke.mts",
    "demo:e2e": "node scripts/demo-e2e.mjs",
    "web:dev": "pnpm --filter web dev",
    "web:build": "pnpm --filter web build"
  },
  "packageManager": "pnpm@11.1.3",
  "devDependencies": {
    "puppeteer-core": "^25.3.0"
  }
}
